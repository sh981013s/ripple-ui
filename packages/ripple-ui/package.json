{
  "name": "@sh981013s/ripple-ui",
  "version": "0.1.1",
  "description": "Calm, mobile-first React UI components for structured product surfaces.",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sh981013s/ripple-ui.git",
    "directory": "packages/ripple-ui"
  },
  "homepage": "https://sh981013s.github.io/ripple-ui/",
  "bugs": {
    "url": "https://github.com/sh981013s/ripple-ui/issues"
  },
  "keywords": [
    "react",
    "design-system",
    "component-library",
    "ui",
    "ripple-ui",
    "mobile-first",
    "themeable",
    "fintech-ui",
    "vibe-coding",
    "ai-ui"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/generate-deep-types.mjs && rm -rf dist && tsc -p tsconfig.json && cp src/styles.css dist/styles.css && cp src/tokens.css dist/tokens.css && cp types/index.d.ts dist/index.d.ts && mkdir -p dist/components dist/primitives && cp types/components/*.d.ts dist/components/ && cp types/primitives/*.d.ts dist/primitives/",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./primitives/*": {
      "types": "./dist/primitives/*.d.ts",
      "import": "./dist/primitives/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "typesVersions": {
    "*": {
      "components/*": [
        "dist/components/*"
      ],
      "primitives/*": [
        "dist/primitives/*"
      ],
      "hooks/*": [
        "dist/hooks/*"
      ],
      "utils/*": [
        "dist/utils/*"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
